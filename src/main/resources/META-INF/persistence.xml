<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="default" transaction-type="JTA">
        <jta-data-source>jdbc/PriceWatchResource</jta-data-source>
        <class>com.pricewatch.pricewatch.entities.Users</class>
        <class>com.pricewatch.pricewatch.entities.Products</class>
        <class>com.pricewatch.pricewatch.entities.ProductLink</class>
        <class>com.pricewatch.pricewatch.entities.PriceHistory</class>
        <class>com.pricewatch.pricewatch.entities.Roles</class>
        <class>com.pricewatch.pricewatch.entities.WatchList</class>

        <properties>
<!--            create-or-extend-tables-->
            <property name="jakarta.persistence.schema-generation.database.action" value="none" />
        </properties>

    </persistence-unit>
</persistence>
